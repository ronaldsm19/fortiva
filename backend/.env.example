# ============================================================
# Base de datos — MongoDB (Atlas o replica set local)
# ============================================================
# DATABASE_URL: cadena de conexión de MongoDB. Debe incluir el nombre de la BD.
#   Atlas → Connect → Drivers → copia la SRV string y agrega "/fortiva".
#   IMPORTANTE: Prisma requiere un REPLICA SET (Atlas ya lo es) para escrituras
#   anidadas y transacciones. Para Mongo local, arráncalo como replica set.
DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/fortiva?retryWrites=true&w=majority"

# Ejemplo local (replica set de un nodo):
# DATABASE_URL="mongodb://localhost:27017/fortiva?replicaSet=rs0"

# ============================================================
# Servidor
# ============================================================
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ============================================================
# JWT
# ============================================================
JWT_ACCESS_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
JWT_REFRESH_SECRET="cambia-esto-por-otro-secreto-distinto"
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Días de prueba gratis (arranca en el primer login)
TRIAL_DAYS=7
