# Modo de la capa de datos del frontend.
#   mock → usa datos locales (Fase 1, sin backend)
#   api  → consume el backend REST real (Fase 3+)
VITE_API_MODE=mock

# URL base del backend REST (se usa cuando VITE_API_MODE=api)
VITE_API_URL=http://localhost:4000/api/v1

# Tasa de cambio mock USD → CRC (en producción vendrá de config/servicio)
VITE_CRC_RATE=525
